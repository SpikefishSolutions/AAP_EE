#!/bin/bash
# ============================================================
# Pre-commit hook — blocks commits containing sensitive data
#
# Install with:
#   git config core.hooksPath .githooks
# ============================================================
set -e

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'
BLOCKED=0

# ── 1. Forbidden files ──────────────────────────────────────
FORBIDDEN_FILES=(
  ".env"
  ".env.local"
  ".env.production"
  ".git-credentials"
  ".secret_key"
  "id_rsa"
  "id_ecdsa"
  "id_ed25519"
)

staged_files=$(git diff --cached --name-only --diff-filter=ACM)

for file in $staged_files; do
  basename=$(basename "$file")
  for forbidden in "${FORBIDDEN_FILES[@]}"; do
    if [ "$basename" = "$forbidden" ]; then
      echo -e "${RED}BLOCKED:${NC} $file — forbidden file type"
      BLOCKED=1
    fi
  done
done

# ── 2. Secret patterns ──────────────────────────────────────
SECRET_PATTERNS=(
  'sk-ant-[a-zA-Z0-9]'                     # Anthropic API key
  'sk-or-[a-zA-Z0-9]'                      # OpenRouter API key
  'AIza[0-9A-Za-z\-_]{35}'                 # Google / Gemini API key
  'ghp_[a-zA-Z0-9]{36}'                    # GitHub personal access token
  'gho_[a-zA-Z0-9]{36}'                    # GitHub OAuth token
  'github_pat_[a-zA-Z0-9]'                 # GitHub fine-grained PAT
  'AKIA[0-9A-Z]{16}'                       # AWS access key
  'sk-[a-zA-Z0-9]{32,}'                    # OpenAI-style key
  'BEGIN.*(RSA|EC|DSA|PRIVATE) PRIVATE KEY' # Private keys
  'password\s*=\s*["\x27][^"\x27]{8,}'     # Hardcoded passwords (8+ chars)
)

for file in $staged_files; do
  if file "$file" 2>/dev/null | grep -q "binary"; then
    continue
  fi
  case "$file" in
    *.min.js|*.min.css|*/vendor/*) continue ;;
  esac

  for pattern in "${SECRET_PATTERNS[@]}"; do
    matches=$(git diff --cached -U0 "$file" 2>/dev/null | grep "^+" | grep -E "$pattern" || true)
    if [ -n "$matches" ]; then
      echo -e "${RED}BLOCKED:${NC} $file — matches secret pattern: ${YELLOW}${pattern}${NC}"
      echo "  $matches" | head -3
      BLOCKED=1
    fi
  done
done

# ── 3. Large files ──────────────────────────────────────────
MAX_SIZE=1048576  # 1MB
for file in $staged_files; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt "$MAX_SIZE" ]; then
      echo -e "${YELLOW}WARNING:${NC} $file is $(( size / 1024 ))KB — consider if this should be committed"
    fi
  fi
done

# ── Result ──────────────────────────────────────────────────
if [ "$BLOCKED" -ne 0 ]; then
  echo ""
  echo -e "${RED}Commit blocked.${NC} Fix the issues above or use ${YELLOW}git commit --no-verify${NC} to bypass (not recommended)."
  exit 1
fi
